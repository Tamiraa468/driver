# ----------------------------------------------------------------------------
# Diploma benchmarks environment. Copy to .env and fill in.
# IMPORTANT: SERVICE_ROLE key MUST stay out of version control and the mobile
# app bundle. Only used locally by benchmark scripts.
# ----------------------------------------------------------------------------

SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Test user credentials for the "authenticated role" benchmark run. The user
# must be a courier with an approved KYC status so RLS allows full RPC access.
BENCH_USER_EMAIL=bench.courier@example.com
BENCH_USER_PASSWORD=<password>

# Load-test scaling: number of virtual couriers to provision for k6
LOAD_TEST_MAX_COURIERS=200

# Seed settings
SEED_TASK_COUNT=60
SEED_ORG_ID=<uuid of an existing org in delivery_tasks>
