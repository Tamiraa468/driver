# ----------------------------------------------------------------------------
# ePOD security-test environment. Copy to .env and fill in.
#
# !!! STAGING ONLY !!!
# Never point this at a production Supabase project. The scripts will refuse
# to run if NODE_ENV=production or SUPABASE_URL matches SUPABASE_PROD_URL.
# ----------------------------------------------------------------------------

NODE_ENV=staging

SUPABASE_URL=https://<staging-project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Explicit abort fence — if SUPABASE_URL equals this value, the test aborts.
# Duplicate your PROD url here so CI/runbooks catch accidental misconfig.
SUPABASE_PROD_URL=https://<prod-project>.supabase.co

# Primary bench courier for Scenario A (approved + able to claim)
BENCH_COURIER_EMAIL=bench.courier@example.com
BENCH_COURIER_PASSWORD=<password>

# Scenario B uses 10 courier accounts — either provide a prefix (emails will
# be synthesized as <prefix>+0@domain ... +9@domain) OR provide a JSON array
# via BENCH_MULTI_COURIERS=[{"email":"...","password":"..."}]
BENCH_MULTI_PREFIX=bench.courier.multi
BENCH_MULTI_DOMAIN=example.com
BENCH_MULTI_PASSWORD=<password>

# Org that owns the staging pickup location so we can insert delivery_tasks
SEED_ORG_ID=<uuid>
